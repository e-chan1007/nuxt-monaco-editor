{
  "name": "nuxt-monaco-editor",
  "description": "Integrate monaco-editor with Nuxt",
  "keywords": [
    "monaco-editor",
    "nuxt"
  ],
  "author": "e-chan1007",
  "homepage": "https://e-chan1007.github.io/nuxt-monaco-editor",
  "repository": {
    "type": "git",
    "url": "https://github.com/e-chan1007/nuxt-monaco-editor.git"
  },
  "version": "1.4.0",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./dist/module.mjs",
      "types": "./dist/types.d.mts"
    },
    "./dist/*": {
      "import": "./dist/*"
    }
  },
  "main": "./dist/module.mjs",
  "files": [
    "dist"
  ],
  "scripts": {
    "postpack": "pinst --enable",
    "build": "nuxt-module-build build && pnpm loc:build",
    "lint": "eslint --ext .js,.cjs,.mjs,.ts,.cts,.mts,.vue . && remark . -q",
    "test": "nuxt test",
    "prepack": "pinst --disable && nuxt-module-build build && pnpm loc:build",
    "release": "standard-version",
    "dev": "nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt prepare playground && pnpm loc:build",
    "docs:dev": "pnpm --filter nuxt-monaco-editor-docs dev",
    "docs:generate": "pnpm --filter nuxt-monaco-editor-docs generate",
    "docs:prepare": "pnpm --filter nuxt-monaco-editor-docs prepare",
    "docs:preview": "pnpm --filter nuxt-monaco-editor-docs preview",
    "loc:build": "jiti scripts/build-loc.ts"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.4",
    "defu": "^6.1.4",
    "vite-plugin-static-copy": "^4.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@nuxt/eslint-config": "^1.8.0",
    "@nuxt/module-builder": "1.0.2",
    "@nuxt/test-utils": "4.0.3",
    "eslint": "^10.3.0",
    "jiti": "^2.7.0",
    "lefthook": "^2.1.6",
    "monaco-editor": "^0.55.1",
    "nuxt": "^4.4.4",
    "pinst": "^3.0.0",
    "playwright-core": "^1.54.2",
    "remark-cli": "^12.0.1",
    "remark-lint": "^10.0.1",
    "remark-preset-lint-recommended": "^7.0.1",
    "standard-version": "^9.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.8"
  },
  "peerDependencies": {
    "monaco-editor": "*"
  },
  "resolutions": {
    "@unhead/vue": "^2"
  },
  "remarkConfig": {
    "plugins": [
      "remark-preset-lint-recommended",
      [
        "remark-lint-list-item-indent",
        "mixed"
      ]
    ]
  },
  "packageManager": "pnpm@10.32.1"
}
